# Postgres connection string. Locally this points at the docker-compose postgres
# service; in production it's the connection string Dokploy gives you for the
# managed Postgres database (see docs/adr/0001-self-hosted-postgres-and-blob-storage.md).
DATABASE_URL=postgres://payload:payload@localhost:5432/payload
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Origin Payload serves from. Must match the URL you open in the browser, otherwise
# the admin panel's client-side requests go cross-origin and the session cookie is
# dropped (the admin then reports you as logged out).
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# S3-compatible object storage for media uploads (RustFS in this project). Locally
# this points at the docker-compose rustfs service; in production it's the RustFS
# bucket provisioned on Dokploy. Do not reuse the bucket used for Dokploy backups —
# media needs public read, backups don't.
S3_BUCKET=media
S3_REGION=auto
# Endpoint the app writes to (internal/private).
S3_ENDPOINT=http://localhost:9000
# Base URL the browser reads from (public bucket URL, no path/api proxy).
S3_PUBLIC_URL=http://localhost:9000/media
S3_ACCESS_KEY_ID=rustfsadmin
S3_SECRET_ACCESS_KEY=rustfsadmin

# Google Analytics 4 — get this from analytics.google.com (format: G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# DeepL API — free tier at deepl.com/pro#developer (format: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx:fx)
DEEPL_API_KEY=
